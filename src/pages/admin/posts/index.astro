---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import PostList from '@/components/admin/PostList';
import { getPublishedContentPosts } from '@/lib/content-posts';

const initialPosts = (await getPublishedContentPosts()).map((post) => ({
  id: post.slug,
  title: post.title,
  description: post.description,
  status: 'published' as const,
  tags: post.tags,
  slug: post.slug,
  createdAt: post.pubDate,
  updatedDate: post.updatedDate,
  readingTime: post.readingTime,
  pubDate: post.pubDate,
}));
---

<BaseLayout title="포스트 관리 - Cruz Lab Admin">
  <PostList client:only="react" initialPosts={initialPosts} />
</BaseLayout>
