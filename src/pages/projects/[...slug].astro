---
export const prerender = true;

import { getProjectEntryPost } from '@/lib/project-notes';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const allProjectPosts = await getCollection('projectPosts');
const entryPost = getProjectEntryPost(allProjectPosts, project.id);

if (!entryPost) {
  return Astro.redirect('/projects');
}

return Astro.redirect(`/projects/${project.id}/notes/${entryPost.id}`);
---
