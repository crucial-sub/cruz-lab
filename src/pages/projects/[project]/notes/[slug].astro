---
export const prerender = true;

import FadeInSection from '@/components/islands/FadeInSection';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  const projectMap = new Map(projects.map((project) => [project.id, project]));
  const projectPosts = await getCollection('projectPosts');

  return projectPosts
    .filter((entry) => entry.data.status === 'published')
    .map((entry) => {
      const project = projectMap.get(entry.data.project);

      if (!project) {
        return null;
      }

      return {
        params: {
          project: project.id,
          slug: entry.id,
        },
        props: {
          project,
          note: entry,
        },
      };
    })
    .filter(Boolean);
}

const { project, note } = Astro.props;
const { Content } = await render(note);

const projectPosts = (await getCollection('projectPosts'))
  .filter((entry) => entry.data.project === project.id && entry.data.status === 'published')
  .sort((a, b) => a.data.order - b.data.order);

const currentIndex = projectPosts.findIndex((entry) => entry.id === note.id);
const previousNote = currentIndex > 0 ? projectPosts[currentIndex - 1] : null;
const nextNote = currentIndex >= 0 && currentIndex < projectPosts.length - 1 ? projectPosts[currentIndex + 1] : null;

const {
  title: projectTitle,
  description: projectDescription,
  image,
  tags,
} = project.data;

const chapterTitle = note.data.chapterLabel || `Part ${note.data.order}`;
const showPartNav = projectPosts.length > 1;
---

<BaseLayout
  title={`${note.data.title} | ${projectTitle}`}
  description={note.data.description}
  image={image?.src}
  tags={tags}
>
  <article class="py-8">
    <FadeInSection client:visible>
      <div class="mb-8 flex flex-wrap items-center gap-3 text-sm text-text-secondary">
        <a
          href="/projects"
          class="group inline-flex items-center gap-2 transition-colors hover:text-brand"
        >
          <svg class="h-4 w-4 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
          프로젝트 목록
        </a>
        <span class="text-text-muted">/</span>
        <span class="text-text-primary">{projectTitle}</span>
      </div>
    </FadeInSection>

    <FadeInSection client:visible delay={0.1}>
      <section class="mb-10 border-b border-border pb-8">
        <div class="mb-4 flex flex-wrap items-center gap-3">
          <span class="rounded-full border border-brand/25 bg-brand/8 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-brand">
            {chapterTitle}
          </span>
          <span class="text-sm text-text-secondary">
            {projectTitle} · {currentIndex + 1}/{projectPosts.length}
          </span>
        </div>

        <div class="max-w-4xl">
          <h1 class="text-4xl font-extrabold md:text-5xl">{note.data.title}</h1>
          <p class="mt-4 text-lg leading-8 text-text-secondary">
            {note.data.description}
          </p>
        </div>

        {
          showPartNav && (
            <nav class="mt-6 flex flex-wrap gap-2">
              {projectPosts.map((entry) => {
                const isActive = entry.id === note.id;
                return (
                  <a
                    href={`/projects/${project.id}/notes/${entry.id}`}
                    class:list={[
                      'inline-flex items-center gap-2 rounded-full border px-4 py-2 text-sm font-medium transition-all duration-300',
                      isActive
                        ? 'border-brand/40 bg-brand/10 text-brand'
                        : 'border-border bg-bg-surface text-text-secondary hover:border-brand/30 hover:text-brand',
                    ]}
                  >
                    <span>{entry.data.chapterLabel || `Part ${entry.data.order}`}</span>
                    <span class:list={[isActive ? 'text-text-primary' : 'text-text-secondary']}>
                      {entry.data.title}
                    </span>
                  </a>
                );
              })}
            </nav>
          )
        }
      </section>
    </FadeInSection>

    <FadeInSection client:visible delay={0.2}>
      <section class="prose prose-lg max-w-none">
        <Content />
      </section>
    </FadeInSection>

    <FadeInSection client:visible delay={0.3}>
      <section class="mt-14 grid gap-4 border-t border-border pt-10 md:grid-cols-2">
        {
          previousNote ? (
            <a
              href={`/projects/${project.id}/notes/${previousNote.id}`}
              class="group rounded-[24px] border border-border bg-bg-surface px-5 py-5 transition-all duration-300 hover:border-brand/30 hover:bg-brand/5"
            >
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-text-secondary">이전 기록</p>
              <p class="mt-3 text-sm font-semibold text-brand">
                {previousNote.data.chapterLabel || `Part ${previousNote.data.order}`}
              </p>
              <h2 class="mt-2 text-lg font-semibold text-text-primary transition-colors group-hover:text-brand">
                {previousNote.data.title}
              </h2>
              <p class="mt-2 text-sm leading-6 text-text-secondary">
                {previousNote.data.description}
              </p>
            </a>
          ) : (
            <a
              href="/projects"
              class="group rounded-[24px] border border-border bg-bg-surface px-5 py-5 transition-all duration-300 hover:border-brand/30 hover:bg-brand/5"
            >
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-text-secondary">프로젝트 목록</p>
              <p class="mt-3 text-sm font-semibold text-brand">Back to Projects</p>
              <h2 class="mt-2 text-lg font-semibold text-text-primary transition-colors group-hover:text-brand">
                {projectTitle}
              </h2>
              <p class="mt-2 text-sm leading-6 text-text-secondary">
                {projectDescription}
              </p>
            </a>
          )
        }

        {
          nextNote ? (
            <a
              href={`/projects/${project.id}/notes/${nextNote.id}`}
              class="group rounded-[24px] border border-border bg-bg-surface px-5 py-5 transition-all duration-300 hover:border-brand/30 hover:bg-brand/5"
            >
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-text-secondary">다음 기록</p>
              <p class="mt-3 text-sm font-semibold text-brand">
                {nextNote.data.chapterLabel || `Part ${nextNote.data.order}`}
              </p>
              <h2 class="mt-2 text-lg font-semibold text-text-primary transition-colors group-hover:text-brand">
                {nextNote.data.title}
              </h2>
              <p class="mt-2 text-sm leading-6 text-text-secondary">
                {nextNote.data.description}
              </p>
            </a>
          ) : (
            <a
              href="/projects"
              class="group rounded-[24px] border border-border bg-bg-surface px-5 py-5 transition-all duration-300 hover:border-brand/30 hover:bg-brand/5"
            >
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-text-secondary">프로젝트 목록</p>
              <p class="mt-3 text-sm font-semibold text-brand">Back to Projects</p>
              <h2 class="mt-2 text-lg font-semibold text-text-primary transition-colors group-hover:text-brand">
                다른 프로젝트 보기
              </h2>
              <p class="mt-2 text-sm leading-6 text-text-secondary">
                현재 글을 다 읽었다면 다른 프로젝트 기록으로 바로 이동할 수 있다.
              </p>
            </a>
          )
        }
      </section>
    </FadeInSection>
  </article>
</BaseLayout>
